# ============================================================
# MiniWorld 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# ============================================================

# --- LLM 配置 (L1 世界构建引擎) ---
# 推荐使用 qwen-plus 或 deepseek-chat
WORLD_ENGINE_API_KEY=your_llm_api_key_here
WORLD_ENGINE_MODEL=qwen-plus
WORLD_ENGINE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
WORLD_ENGINE_MAX_TOKENS=8192

# --- 搜索 API ---
# Tavily: 新闻搜索 (申请地址: https://www.tavily.com/)
TAVILY_API_KEY=your_tavily_api_key_here

# Bocha: 多模态搜索 (申请地址: https://open.bochaai.com/)
BOCHA_API_KEY=your_bocha_api_key_here
BOCHA_BASE_URL=https://api.bocha.cn/v1/ai-search

# --- 关键词优化 LLM (可与 WORLD_ENGINE 共用) ---
KEYWORD_OPTIMIZER_API_KEY=your_llm_api_key_here
KEYWORD_OPTIMIZER_MODEL=qwen-plus
KEYWORD_OPTIMIZER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- L1 构建参数 ---
MAX_BUILD_ITERATIONS=5
SAVE_INTERMEDIATE_STATES=false

# --- 搜索路由参数（与 PerceptionEngine 一致）---
MAX_RESULTS_PER_TASK=10
MAX_SEARCH_TASKS=15
SEARCH_CONCURRENCY=5
SEARCH_TIMEOUT=30
MAX_SAMPLED_PER_DIMENSION=15

# --- L2 演变参数 ---
EVOLUTION_ENGINE_API_KEY=your-llm-api-key
EVOLUTION_ENGINE_MODEL=qwen-plus
EVOLUTION_ENGINE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EVOLUTION_MAX_TOKENS=8192
EVOLUTION_MAX_TICKS=10
EVOLUTION_AGENT_TEMPERATURE=0.7
EVOLUTION_WORLD_TEMPERATURE=0.3

# --- 输出路径 ---
WORLDS_DIR=worlds
EVOLUTIONS_DIR=evolutions
LOGS_DIR=logs
